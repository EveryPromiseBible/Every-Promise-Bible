# OS / filesystem cruft
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# Editor / IDE
.vscode/
.idea/
*.swp
*~

# Local scratch / logs (not part of the app)
*.log
tmp/
scratch/

# Python bytecode cache from the tools/ reorder scripts
__pycache__/
*.pyc

# Claude Code per-user local settings (personal, not shared)
.claude/settings.local.json
.claude/settings.local.json.bak

# Downloaded public-domain lexicon / Greek sources (large; reproducible via
# the URLs documented in tools/lex_build.py and tools/co2_tags.py headers)
tools/data/*.xml
tools/data/*.zip
tools/data/strongs-greek.js
tools/data/*-morphgnt.txt

# Regenerable per-chapter word dumps (co2_words.py --json)
tools/data/co2_words_*.json
tools/data/KJV.json

# build output (assembled by the host, not committed)
dist/

# Promise batches are staging, not source. Once add_promises.py --merge has
# written them into data/promises.js the file must leave promises_new/ or it
# is re-read as a duplicate and blocks the next merge.
tools/promises_new/
