{"G1820": {"greek": "ἐξαπορέομαι", "translit": "exaporéomai", "pronunciation": "ex-ap-or-eh'-om-ahee", "derivation": "middle voice from (G1537) and (G639);", "definition": "to be utterly at a loss, i.e. despond", "kjv": "(in) despair."}, "G610": {"greek": "ἀπόκριμα", "translit": "apókrima", "pronunciation": "ap-ok'-ree-mah", "derivation": "from (G611) (in its original sense of judging);", "definition": "a judicial decision", "kjv": "sentence."}, "G5082": {"greek": "τηλικοῦτος", "translit": "tēlikoûtos", "pronunciation": "tay-lik-oo'-tos", "derivation": "from a compound of (G3588) with (G2245) and (G3778);", "definition": "such as this, i.e. (in (figurative) magnitude) so vast", "kjv": "so great, so mighty."}, "G4943": {"greek": "συνυπουργέω", "translit": "synypourgéō", "pronunciation": "soon-oop-oorg-eh'-o", "derivation": "from (G4862) and a derivative of a compound of (G5259) and the base of (G2041);", "definition": "to be a co-auxiliary, i.e. assist", "kjv": "help together."}, "G41": {"greek": "ἁγιότης", "translit": "hagiótēs", "pronunciation": "hag-ee-ot'-ace", "derivation": "from (G40);", "definition": "sanctity (i.e. properly, the state)", "kjv": "holiness."}, "G4056": {"greek": "περισσοτέρως", "translit": "perissotérōs", "pronunciation": "per-is-sot-er'-oce", "derivation": "adverb from (G4055);", "definition": "more superabundantly", "kjv": "more abundant(-ly), X the more earnest, (more) exceedingly, more frequent, much more, the rather."}, "G4006": {"greek": "πεποίθησις", "translit": "pepoíthēsis", "pronunciation": "pep-oy'-thay-sis", "derivation": "from the perfect of the alternate of (G3958);", "definition": "reliance", "kjv": "confidence, trust."}, "G1644": {"greek": "ἐλαφρία", "translit": "elaphría", "pronunciation": "el-af-ree'-ah", "derivation": "from (G1645);", "definition": "levity (figuratively), i.e. fickleness", "kjv": "lightness."}, "G4610": {"greek": "Σιλουανός", "translit": "Silouanós", "pronunciation": "sil-oo-an-os'", "derivation": "of Latin origin;", "definition": "\"silvan\"; Silvanus, a Christian", "kjv": "Silvanus."}, "G728": {"greek": "ἀῤῥαβών", "translit": "arrhabṓn", "pronunciation": "ar-hrab-ohn'", "derivation": "of Hebrew origin ((G6162));", "definition": "a pledge, i.e. part of the purchase-money or property given in advance as security for the rest", "kjv": "earnest."}, "G1912": {"greek": "ἐπιβαρέω", "translit": "epibaréō", "pronunciation": "ep-ee-bar-eh'-o", "derivation": "from (G1909) and (G916);", "definition": "to be heavy upon, i.e. (pecuniarily) to be expensive to; figuratively, to be severe towards", "kjv": "be chargeable to, overcharge."}, "G2009": {"greek": "ἐπιτιμία", "translit": "epitimía", "pronunciation": "ep-ee-tee-mee'-ah", "derivation": "from a compound of (G1909) and (G5092);", "definition": "properly, esteem, i.e. citizenship; used (in the sense of (G2008)) of a penalty", "kjv": "punishment."}, "G5121": {"greek": "τοὐναντίον", "translit": "tounantíon", "pronunciation": "too-nan-tee'-on", "derivation": "contraction for the neuter of (G3588) and (G1726);", "definition": "on the contrary", "kjv": "contrariwise."}, "G2964": {"greek": "κυρόω", "translit": "kyróō", "pronunciation": "koo-ro'-o", "derivation": "from the same as (G2962);", "definition": "to make authoritative, i.e. ratify", "kjv": "confirm."}, "G4122": {"greek": "πλεονεκτέω", "translit": "pleonektéō", "pronunciation": "pleh-on-cek-teh'-o", "derivation": "from (G4123);", "definition": "to be covetous, i.e. (by implication) to over-reach", "kjv": "get an advantage, defraud, make a gain."}, "G3540": {"greek": "νόημα", "translit": "nóēma", "pronunciation": "no'-ay-mah", "derivation": "from (G3539);", "definition": "a perception, i.e. purpose, or (by implication) the intellect, disposition, itself", "kjv": "device, mind, thought."}, "G5103": {"greek": "Τίτος", "translit": "Títos", "pronunciation": "tee'-tos", "derivation": "of Latin origin but uncertain significance;", "definition": "Titus, a Christian", "kjv": "Titus."}, "G2358": {"greek": "θριαμβεύω", "translit": "thriambeúō", "pronunciation": "three-am-byoo'-o", "derivation": "from a prolonged compound of the base of (G2360);", "definition": "and a derivative of (G680) (meaning a noisy iambus, sung in honor of Bacchus); to make an acclamatory procession, i.e. (figuratively) to conquer or (by Hebraism) to give victory", "kjv": "(cause) to triumph (over)."}, "G2175": {"greek": "εὐωδία", "translit": "euōdía", "pronunciation": "yoo-o-dee'-ah", "derivation": "from a compound of (G2095) and a derivative of (G3605);", "definition": "good-scentedness, i.e. fragrance", "kjv": "sweet savour (smell, -smelling)."}, "G2585": {"greek": "καπηλεύω", "translit": "kapēleúō", "pronunciation": "kap-ale-yoo'-o", "derivation": "from (a huckster);", "definition": "to retail, i.e. (by implication) to adulterate (figuratively)", "kjv": "corrupt."}, "G4956": {"greek": "συστατικός", "translit": "systatikós", "pronunciation": "soos-tat-ee-kos'", "derivation": "from a derivative of (G4921);", "definition": "introductory, i.e. recommendatory", "kjv": "of commendation."}, "G3188": {"greek": "μέλαν", "translit": "mélan", "pronunciation": "mel'-an", "derivation": "neuter of (G3189) as noun;", "definition": "ink", "kjv": "ink."}, "G4109": {"greek": "πλάξ", "translit": "pláx", "pronunciation": "plax", "derivation": "from (G4111);", "definition": "a moulding-board, i.e. flat surface (\"plate\", or tablet, literally or figuratively)", "kjv": "table."}, "G2426": {"greek": "ἱκανότης", "translit": "hikanótēs", "pronunciation": "hik-an-ot'-ace", "derivation": "from (G2425);", "definition": "ability", "kjv": "sufficiency."}, "G2427": {"greek": "ἱκανόω", "translit": "hikanóō", "pronunciation": "hik-an-o'-o", "derivation": "from (G2425);", "definition": "to enable, i.e. qualify", "kjv": "make able (meet)."}, "G1795": {"greek": "ἐντυπόω", "translit": "entypóō", "pronunciation": "en-too-po'-o", "derivation": "from (G1722) and a derivative of (G5179);", "definition": "to enstamp, i.e. engrave", "kjv": "engrave."}, "G2633": {"greek": "κατάκρισις", "translit": "katákrisis", "pronunciation": "kat-ak'-ree-sis", "derivation": "from (G2632);", "definition": "sentencing adversely (the act)", "kjv": "condemn(-ation)."}, "G5235": {"greek": "ὑπερβάλλω", "translit": "hyperbállō", "pronunciation": "hoop-er-bal'-lo", "derivation": "from (G5228) and (G906);", "definition": "to throw beyod the usual mark, i.e. (figuratively) to surpass (only active participle supereminent)", "kjv": "exceeding, excel, pass."}, "G2571": {"greek": "κάλυμα", "translit": "kályma", "pronunciation": "kal'-oo-mah", "derivation": "from (G2572);", "definition": "a cover, i.e. veil", "kjv": "vail."}, "G343": {"greek": "ἀνακαλύπτω", "translit": "anakalýptō", "pronunciation": "an-ak-al-oop'-to", "derivation": "from (G303) (in the sense of reversal) and (G2572);", "definition": "to unveil", "kjv": "open, (un-)taken away."}, "G2259": {"greek": "ἡνίκα", "translit": "hēníka", "pronunciation": "hay-nee'-kah", "derivation": "of uncertain affinity;", "definition": "at which time", "kjv": "when."}, "G2734": {"greek": "κατοπτρίζομαι", "translit": "katoptrízomai", "pronunciation": "kat-op-trid'-zom-ahee", "derivation": "middle voice from a compound of (G2596) and a derivative of (G3700) (compare (G2072));", "definition": "to mirror oneself, i.e. to see reflected (figuratively)", "kjv": "behold as in a glass."}, "G550": {"greek": "ἀπειπόμην", "translit": "apeipómēn", "pronunciation": "ap-i-pom'-ane", "derivation": "reflexive past of a compound of (G575) and (G2036);", "definition": "to say off for oneself, i.e. disown", "kjv": "renounce."}, "G1389": {"greek": "δολόω", "translit": "dolóō", "pronunciation": "dol-o'-o", "derivation": "from (G1388);", "definition": "to ensnare, i.e. (figuratively) adulterate", "kjv": "handle deceitfully."}, "G826": {"greek": "αὐγάζω", "translit": "augázō", "pronunciation": "ow-gad'-zo", "derivation": "from (G827);", "definition": "to beam forth (figuratively)", "kjv": "shine."}, "G5462": {"greek": "φωτισμός", "translit": "phōtismós", "pronunciation": "fo-tis-mos'", "derivation": "from (G5461);", "definition": "illumination (figuratively)", "kjv": "light."}, "G3749": {"greek": "ὀστράκινος", "translit": "ostrákinos", "pronunciation": "os-tra'-kin-os", "derivation": "from (\"oyster\") (a tile, i.e. terra cotta);", "definition": "earthen-ware, i.e. clayey; by implication, frail", "kjv": "of earth, earthen."}, "G4729": {"greek": "στενοχωρέω", "translit": "stenochōréō", "pronunciation": "sten-okh-o-reh'-o", "derivation": "from the same as (G4730);", "definition": "to hem in closely, i.e. (figuratively) cramp", "kjv": "distress, straiten."}, "G2598": {"greek": "καταβάλλω", "translit": "katabállō", "pronunciation": "kat-ab-al'-lo", "derivation": "from (G2596) and (G906);", "definition": "to throw down", "kjv": "cast down, lay."}, "G341": {"greek": "ἀνακαινόω", "translit": "anakainóō", "pronunciation": "an-ak-ahee-no'-o", "derivation": "from (G303) and a derivative of (G2537);", "definition": "to renovate", "kjv": "renew."}, "G3910": {"greek": "παραυτίκα", "translit": "parautíka", "pronunciation": "par-ow-tee'-kah", "derivation": "from (G3844) and a derivative of (G846);", "definition": "at the very instant, i.e. momentary", "kjv": "but for a moment."}, "G4636": {"greek": "σκῆνος", "translit": "skēnos", "pronunciation": "skay'-nos", "derivation": "from (G4633);", "definition": "a hut or temporary residence, i.e. (figuratively) the human body (as the abode of the spirit)", "kjv": "tabernacle."}, "G3613": {"greek": "οἰκητήριον", "translit": "oikētḗrion", "pronunciation": "oy-kay-tay'-ree-on", "derivation": "neuter of a presumed derivative of (G3611) (equivalent to (G3612));", "definition": "a residence (literally or figuratively)", "kjv": "habitation, house."}, "G1902": {"greek": "ἐπενδύομαι", "translit": "ependýomai", "pronunciation": "ep-en-doo'-om-ahee", "derivation": "middle voice from (G1909) and (G1746);", "definition": "to invest upon oneself", "kjv": "be clothed upon."}, "G2292": {"greek": "θαῤῥέω", "translit": "tharrhéō", "pronunciation": "thar-hreh'-o", "derivation": "another form for (G2293);", "definition": "to exercise courage", "kjv": "be bold, X boldly, have confidence, be confident."}, "G1736": {"greek": "ἐνδημέω", "translit": "endēméō", "pronunciation": "en-day-meh'-o", "derivation": "from a compound of (G1722) and (G1218);", "definition": "to be in one's own country, i.e. home (figuratively)", "kjv": "be at home (present)."}, "G1553": {"greek": "ἐκδημέω", "translit": "ekdēméō", "pronunciation": "ek-day-meh'-o", "derivation": "from a compound of (G1537) and (G1218);", "definition": "to emigrate, i.e. (figuratively) vacate or quit", "kjv": "be absent."}, "G4243": {"greek": "πρεσβεύω", "translit": "presbeúō", "pronunciation": "pres-byoo'-o", "derivation": "from the base of (G4245);", "definition": "to be a senior, i.e. (by implication) act as a representative (figuratively, preacher)", "kjv": "be an ambassador."}, "G1873": {"greek": "ἐπακούω", "translit": "epakoúō", "pronunciation": "ep-ak-oo'-o", "derivation": "from (G1909) and (G191);", "definition": "to hearken (favorably) to", "kjv": "hear."}, "G4349": {"greek": "προσκοπή", "translit": "proskopḗ", "pronunciation": "pros-kop-ay'", "derivation": "from (G4350);", "definition": "a stumbling, i.e. (figuratively and concretely) occasion of sin", "kjv": "offence."}, "G3469": {"greek": "μωμάομαι", "translit": "mōmáomai", "pronunciation": "mo-mah'-om-ahee", "derivation": "from (G3470);", "definition": "to carp at, i.e. censure (discredit)", "kjv": "blame."}, "G70": {"greek": "ἀγρυπνία", "translit": "agrypnía", "pronunciation": "ag-roop-nee'-ah", "derivation": "from (G69);", "definition": "sleeplessness, i.e. a keeping awake", "kjv": "watch."}, "G54": {"greek": "ἁγνότης", "translit": "hagnótēs", "pronunciation": "hag-not'-ace", "derivation": "from (G53);", "definition": "cleanness (the state), i.e. (figuratively) blamelessness", "kjv": "pureness."}, "G1426": {"greek": "δυσφημία", "translit": "dysphēmía", "pronunciation": "doos-fay-mee'-ah", "derivation": "from a compound of (G1418) and (G5345);", "definition": "defamation", "kjv": "evil report."}, "G2162": {"greek": "εὐφημία", "translit": "euphēmía", "pronunciation": "yoo-fay-mee'-ah", "derivation": "from (G2163);", "definition": "good language (\"euphemy\"), i.e. praise (repute)", "kjv": "good report."}, "G2086": {"greek": "ἑτεροζυγέω", "translit": "heterozygéō", "pronunciation": "het-er-od-zoog-eh'-o", "derivation": "from a compound of (G2087) and (G2218);", "definition": "to yoke up differently, i.e. (figuratively) to associate discordantly", "kjv": "unequally yoke together with."}, "G3352": {"greek": "μετοχή", "translit": "metochḗ", "pronunciation": "met-okh-ay'", "derivation": "from (G3348);", "definition": "participation, i.e. intercourse", "kjv": "fellowship."}, "G4857": {"greek": "συμφώνησις", "translit": "symphṓnēsis", "pronunciation": "soom-fo'-nay-sis", "derivation": "from (G4856);", "definition": "accordance", "kjv": "concord."}, "G955": {"greek": "Βελίαλ", "translit": "Belíal", "pronunciation": "bel-ee'-al", "derivation": "of Hebrew origin ((G1100));", "definition": "worthlessness; Belial, as an epithet of Satan", "kjv": "Belial."}, "G4783": {"greek": "συγκατάθεσις", "translit": "synkatáthesis", "pronunciation": "soong-kat-ath'-es-is", "derivation": "from (G4784);", "definition": "a deposition (of sentiment) in company with, i.e. (figuratively) accord with", "kjv": "agreement."}, "G1704": {"greek": "ἐμπεριπατέω", "translit": "emperipatéō", "pronunciation": "em-per-ee-pat-eh'-o", "derivation": "from (G1722) and (G4043);", "definition": "to perambulate on a place, i.e. (figuratively) to be occupied among persons", "kjv": "walk in."}, "G1523": {"greek": "εἰσδέχομαι", "translit": "eisdéchomai", "pronunciation": "ice-dekh'-om-ahee", "derivation": "from (G1519) and (G1209);", "definition": "to take into one's favor", "kjv": "receive."}, "G3841": {"greek": "παντοκράτωρ", "translit": "pantokrátōr", "pronunciation": "pan-tok-rat'-ore", "derivation": "from (G3956) and (G2904);", "definition": "the all-ruling, i.e. God (as absolute and universal sovereign)", "kjv": "Almighty, Omnipotent."}, "G3436": {"greek": "μολυσμός", "translit": "molysmós", "pronunciation": "mol-oos-mos'", "derivation": "from (G3435);", "definition": "a stain; i.e. (figuratively) immorality", "kjv": "filthiness."}, "G3163": {"greek": "μάχη", "translit": "máchē", "pronunciation": "makh'-ay", "derivation": "from (G3164);", "definition": "a battle, i.e. (figuratively) controversy", "kjv": "fighting, strive, striving."}, "G1972": {"greek": "ἐπιπόθησις", "translit": "epipóthēsis", "pronunciation": "ep-ee-poth'-ay-sis", "derivation": "from (G1971);", "definition": "a longing for", "kjv": "earnest (vehement) desire."}, "G24": {"greek": "ἀγανάκτησις", "translit": "aganáktēsis", "pronunciation": "ag-an-ak'-tay-sis", "derivation": "from (G23);", "definition": "indignation", "kjv": "indignation."}, "G53": {"greek": "ἁγνός", "translit": "hagnós", "pronunciation": "hag-nos'", "derivation": "from the same as (G40);", "definition": "properly, clean, i.e. (figuratively) innocent, modest, perfect", "kjv": "chaste, clean, pure."}, "G4432": {"greek": "πτωχεία", "translit": "ptōcheía", "pronunciation": "pto-khi'-ah", "derivation": "from (G4433);", "definition": "beggary, i.e. indigence (literally or figuratively)", "kjv": "poverty."}, "G830": {"greek": "αὐθαίρετος", "translit": "authaíretos", "pronunciation": "ow-thah'-ee-ret-os", "derivation": "from (G846) and the same as (G140);", "definition": "self-chosen, i.e. (by implication) voluntary", "kjv": "of own accord, willing of self."}, "G4278": {"greek": "προενάρχομαι", "translit": "proenárchomai", "pronunciation": "pro-en-ar'-khom-ahee", "derivation": "from (G4253) and (G1728);", "definition": "to commence already", "kjv": "begin (before)."}, "G1103": {"greek": "γνήσιος", "translit": "gnḗsios", "pronunciation": "gnay'-see-os", "derivation": "from the same as (G1077);", "definition": "legitimate (of birth), i.e. genuine", "kjv": "own, sincerity, true."}, "G4433": {"greek": "πτωχεύω", "translit": "ptōcheúō", "pronunciation": "pto-khyoo'-o", "derivation": "from (G4434);", "definition": "to be a beggar, i.e. (by implication) to become indigent (figuratively)", "kjv": "become poor."}, "G4070": {"greek": "πέρυσι", "translit": "pérysi", "pronunciation": "per'-oo-si", "derivation": "adverb from (G4009);", "definition": "the by-gone, i.e. (as noun) last year", "kjv": "+ a year ago."}, "G4295": {"greek": "πρόκειμαι", "translit": "prókeimai", "pronunciation": "prok'-i-mahee", "derivation": "from (G4253) and (G2749);", "definition": "to lie before the view, i.e. (figuratively) to be present (to the mind), to stand forth (as an example or reward)", "kjv": "be first, set before (forth)."}, "G2471": {"greek": "ἰσότης", "translit": "isótēs", "pronunciation": "ee-sot'-ace", "derivation": "", "definition": "likeness (in condition or proportion); by implication, equity", "kjv": "equal(-ity)."}, "G1641": {"greek": "ἐλαττονέω", "translit": "elattonéō", "pronunciation": "el-at-ton-eh-o", "derivation": "from (G1640);", "definition": "to diminish, i.e. fall short", "kjv": "have lack."}, "G4705": {"greek": "σπουδαῖος", "translit": "spoudaîos", "pronunciation": "spoo-dah'-yos", "derivation": "from (G4710);", "definition": "prompt, energetic, earnest", "kjv": "diligent."}, "G4842": {"greek": "συμπέμπω", "translit": "sympémpō", "pronunciation": "soom-pem'-po", "derivation": "from (G4862) and (G3992);", "definition": "to despatch in company", "kjv": "send with."}, "G4724": {"greek": "στέλλω", "translit": "stéllō", "pronunciation": "stel'-lo", "derivation": "probably strengthened from the base of (G2476);", "definition": "properly, to set fast (\"stall\"), i.e. (figuratively) to repress (reflexively, abstain from associating with)", "kjv": "avoid, withdraw self."}, "G100": {"greek": "ἁδρότης", "translit": "hadrótēs", "pronunciation": "had-rot'-ace", "derivation": "from (stout);", "definition": "plumpness, i.e. (figuratively) liberality", "kjv": "abundance."}, "G2042": {"greek": "ἐρεθίζω", "translit": "erethízō", "pronunciation": "er-eth-id'-zo", "derivation": "from a presumed prolonged form of (G2054);", "definition": "to stimulate (especially to anger)", "kjv": "provoke."}, "G532": {"greek": "ἀπαρασκεύαστος", "translit": "aparaskeúastos", "pronunciation": "ap-ar-ask-yoo'-as-tos", "derivation": "from (G1) (as a negative particle) and a derivative of (G3903);", "definition": "unready", "kjv": "unprepared."}, "G5287": {"greek": "ὑπόστασις", "translit": "hypóstasis", "pronunciation": "hoop-os'-tas-is", "derivation": "from a compound of (G5259) and (G2476);", "definition": "a setting under (support), i.e. (figuratively) concretely, essence, or abstractly, assurance (objectively or subjectively)", "kjv": "confidence, confident, person, substance."}, "G4294": {"greek": "προκαταρτίζω", "translit": "prokatartízō", "pronunciation": "prok-at-ar-tid'-zo", "derivation": "from (G4253) and (G2675);", "definition": "to prepare in advance", "kjv": "make up beforehand."}, "G5340": {"greek": "φειδομένως", "translit": "pheidoménōs", "pronunciation": "fi-dom-en'-oce", "derivation": "adverb from participle of (G5339);", "definition": "abstemiously, i.e. stingily", "kjv": "sparingly."}, "G4255": {"greek": "προαιρέομαι", "translit": "proairéomai", "pronunciation": "pro-ahee-reh'-om-ahee", "derivation": "from (G4253) and (G138);", "definition": "to choose for oneself before another thing (prefer), i.e. (by implication) to propose (intend)", "kjv": "purpose."}, "G2431": {"greek": "ἱλαρός", "translit": "hilarós", "pronunciation": "hil-ar-os'", "derivation": "from the same as (G2436);", "definition": "propitious or merry (\"hilarious\"), i.e. prompt or willing", "kjv": "cheerful."}, "G1395": {"greek": "δότης", "translit": "dótēs", "pronunciation": "dot'-ace", "derivation": "from the base of (G1325);", "definition": "a giver", "kjv": "giver."}, "G841": {"greek": "αὐτάρκεια", "translit": "autárkeia", "pronunciation": "ow-tar'-ki-ah", "derivation": "from (G842);", "definition": "self-satisfaction, i.e. (abstractly) contentedness, or (concretely) a competence", "kjv": "contentment, sufficiency."}, "G3993": {"greek": "πένης", "translit": "pénēs", "pronunciation": "pen'-ace", "derivation": "from a primary (to toil for daily subsistence);", "definition": "starving, i.e. indigent", "kjv": "poor."}, "G2023": {"greek": "ἐπιχορηγέω", "translit": "epichorēgéō", "pronunciation": "ep-ee-khor-ayg-eh'-o", "derivation": "from (G1909) and (G5524);", "definition": "to furnish besides, i.e. fully supply, (figuratively) aid or contribute", "kjv": "add, minister (nourishment, unto)."}, "G5524": {"greek": "χορηγέω", "translit": "chorēgéō", "pronunciation": "khor-ayg-eh'-o", "derivation": "from a compound of (G5525) and (G71);", "definition": "to be a dance-leader, i.e. (generally) to furnish", "kjv": "give, minister."}, "G4322": {"greek": "προσαναπληρόω", "translit": "prosanaplēróō", "pronunciation": "pros-an-ap-lay-ro'-o", "derivation": "from (G4314) and (G378);", "definition": "to fill up further, i.e. furnish fully", "kjv": "supply."}, "G3671": {"greek": "ὁμολογία", "translit": "homología", "pronunciation": "hom-ol-og-ee'-ah", "derivation": "from the same as (G3670);", "definition": "acknowledgment", "kjv": "con- (pro-)fession, professed."}, "G411": {"greek": "ἀνεκδιήγητος", "translit": "anekdiḗgētos", "pronunciation": "an-ek-dee-ay'-gay-tos", "derivation": "from (G1) (as a negative particle) and a presumed derivative of (G1555);", "definition": "not expounded in full, i.e. indescribable", "kjv": "unspeakable."}, "G4752": {"greek": "στρατεία", "translit": "strateía", "pronunciation": "strat-i'-ah", "derivation": "from (G4754);", "definition": "military service, i.e. (figuratively) the apostolic career (as one of hardship and danger)", "kjv": "warfare."}, "G2506": {"greek": "καθαίρεσις", "translit": "kathaíresis", "pronunciation": "kath-ah'-ee-res-is", "derivation": "from (G2507);", "definition": "demolition; figuratively, extinction", "kjv": "destruction, pulling down."}, "G3794": {"greek": "ὀχύρωμα", "translit": "ochýrōma", "pronunciation": "okh-oo'-ro-mah", "derivation": "from a remote derivative of (G2192) (meaning to fortify, through the idea of holding safely);", "definition": "a castle (figuratively, argument)", "kjv": "stronghold."}, "G1629": {"greek": "ἐκφοβέω", "translit": "ekphobéō", "pronunciation": "ek-fob-eh'-o", "derivation": "from (G1537) and (G5399);", "definition": "to frighten utterly", "kjv": "terrify."}, "G1469": {"greek": "ἐγκρίνω", "translit": "enkrínō", "pronunciation": "eng-kree'-no", "derivation": "from (G1722) and (G2919);", "definition": "to judge in, i.e. count among", "kjv": "make of the number."}, "G280": {"greek": "ἄμετρος", "translit": "ámetros", "pronunciation": "am'-et-ros", "derivation": "from (G1) (as a negative particle) and (G3358);", "definition": "immoderate", "kjv": "(thing) without measure."}, "G2583": {"greek": "κανών", "translit": "kanṓn", "pronunciation": "kan-ohn'", "derivation": "from (a straight reed, i.e. rod);", "definition": "a rule (\"canon\"), i.e. (figuratively) a standard (of faith and practice); by implication, a boundary, i.e. (figuratively) a sphere (of activity)", "kjv": "line, rule."}, "G2185": {"greek": "ἐφικνέομαι", "translit": "ephiknéomai", "pronunciation": "ef-ik-neh'-om-ahee", "derivation": "from (G1909) and a cognate of (G2240);", "definition": "to arrive upon, i.e. extend to", "kjv": "reach."}, "G5239": {"greek": "ὑπερεκτείνω", "translit": "hyperekteínō", "pronunciation": "hoop-er-ek-ti'-no", "derivation": "from (G5228) and (G1614);", "definition": "to extend inordinately", "kjv": "stretch beyond."}, "G5238": {"greek": "ὑπερέκεινα", "translit": "hyperékeina", "pronunciation": "hoop-er-ek'-i-nah", "derivation": "from (G5228) and the neuter plural of (G1565);", "definition": "above those parts, i.e. still farther", "kjv": "beyond."}, "G718": {"greek": "ἁρμόζω", "translit": "harmózō", "pronunciation": "har-mod'-zo", "derivation": "from (G719);", "definition": "to joint, i.e. (figuratively) to woo (reflexively, to betroth)", "kjv": "espouse."}, "G2096": {"greek": "Εὖα", "translit": "Eûa", "pronunciation": "yoo'-ah", "derivation": "of Hebrew origin ((G2332));", "definition": "Eua (or Eva, i.e. Chavvah), the first woman", "kjv": "Eve."}, "G4813": {"greek": "συλάω", "translit": "syláō", "pronunciation": "soo-lah'-o", "derivation": "from a derivative of (to strip; probably akin to (G138); compare (G4661));", "definition": "to despoil", "kjv": "rob."}, "G2655": {"greek": "καταναρκάω", "translit": "katanarkáō", "pronunciation": "kat-an-ar-kah'-o", "derivation": "from (G2596) and (to be numb);", "definition": "to grow utterly torpid, i.e. (by implication) slothful (figuratively, expensive)", "kjv": "be burdensome (chargeable)."}, "G4": {"greek": "ἀβαρής", "translit": "abarḗs", "pronunciation": "ab-ar-ace'", "derivation": "from (G1) (as a negative particle) and (G922);", "definition": "weightless, i.e. (figuratively) not burdensome", "kjv": "from being burdensome."}, "G5570": {"greek": "ψευδαπόστολος", "translit": "pseudapóstolos", "pronunciation": "psyoo-dap-os'-tol-os", "derivation": "from (G5571) and (G652);", "definition": "a spurious apostle, i.e. pretended pracher", "kjv": "false teacher."}, "G1386": {"greek": "δόλιος", "translit": "dólios", "pronunciation": "dol'-ee-os", "derivation": "from (G1388);", "definition": "guileful", "kjv": "deceitful."}, "G2295": {"greek": "θαῦμα", "translit": "thaûma", "pronunciation": "thos'-mah", "derivation": "apparently from a form of (G2300);", "definition": "wonder (properly concrete; but by implication, abstract)", "kjv": "admiration."}, "G2615": {"greek": "καταδουλόω", "translit": "katadoulóō", "pronunciation": "kat-ad-oo-lo'-o", "derivation": "from (G2596) and (G1402);", "definition": "to enslave utterly", "kjv": "bring into bondage."}, "G3912": {"greek": "παραφρονέω", "translit": "paraphronéō", "pronunciation": "par-af-ron-eh'-o", "derivation": "from (G3844) and (G5426);", "definition": "to misthink, i.e. be insane (silly)", "kjv": "as a fool."}, "G5234": {"greek": "ὑπερβαλλόντως", "translit": "hyperballóntōs", "pronunciation": "hoop-er-bal-lon'-toce", "derivation": "adverb from present participle active of (G5235);", "definition": "excessively", "kjv": "beyond measure."}, "G3999": {"greek": "πεντάκις", "translit": "pentákis", "pronunciation": "pen-tak-ece'", "derivation": "multiplicative adverb from (G4002);", "definition": "five times", "kjv": "five times."}, "G530": {"greek": "ἅπαξ", "translit": "hápax", "pronunciation": "hap'-ax", "derivation": "probably from (G537);", "definition": "one (or a single) time (numerically or conclusively)", "kjv": "once."}, "G3489": {"greek": "ναυαγέω", "translit": "nauagéō", "pronunciation": "now-ag-eh'-o", "derivation": "from a compound of (G3491) and (G71);", "definition": "to be shipwrecked (stranded, \"navigate\"), literally or figuratively", "kjv": "make (suffer) shipwreck."}, "G3574": {"greek": "νυχθήμερον", "translit": "nychthḗmeron", "pronunciation": "nookh-thay'-mer-on", "derivation": "from (G3571) and (G2250);", "definition": "a day-and-night, i.e. full day of twenty-four hours", "kjv": "night and day."}, "G1037": {"greek": "βυθός", "translit": "bythós", "pronunciation": "boo-thos'", "derivation": "a variation of (G899);", "definition": "depth, i.e. (by implication) the sea", "kjv": "deep."}, "G5569": {"greek": "ψευδάδελφος", "translit": "pseudádelphos", "pronunciation": "psyoo-dad'-el-fos", "derivation": "from (G5571) and (G80);", "definition": "a spurious brother, i.e. pretended associate", "kjv": "false brethren."}, "G3449": {"greek": "μόχθος", "translit": "móchthos", "pronunciation": "mokh'-thos", "derivation": "from the base of (G3425);", "definition": "toil, i.e. (by implication) sadness", "kjv": "painfulness, travail."}, "G1373": {"greek": "δίψος", "translit": "dípsos", "pronunciation": "dip'-sos", "derivation": "of uncertain affinity;", "definition": "thirst", "kjv": "thirst."}, "G1481": {"greek": "ἐθνάρχης", "translit": "ethnárchēs", "pronunciation": "eth-nar'-khace", "derivation": "from (G1484) and (G746);", "definition": "the governor (not king) of a district", "kjv": "ethnarch."}, "G702": {"greek": "Ἀρέτας", "translit": "Arétas", "pronunciation": "ar-et'-as", "derivation": "of foreign origin;", "definition": "Aretas, an Arabian", "kjv": "Aretas."}, "G5432": {"greek": "φρουρέω", "translit": "phrouréō", "pronunciation": "froo-reh'-o", "derivation": "from a compound of (G4253) and (G3708);", "definition": "to be a watcher in advance, i.e. to mount guard as a sentinel (post spies at gates); figuratively, to hem in, protect", "kjv": "keep (with a garrison)."}, "G1153": {"greek": "Δαμασκηνός", "translit": "Damaskēnós", "pronunciation": "dam-as-kay-nos'", "derivation": "from (G1154);", "definition": "a Damascene or inhabitant of Damascus", "kjv": "Damascene."}, "G4553": {"greek": "σαργάνη", "translit": "sargánē", "pronunciation": "sar-gan'-ay", "derivation": "apparently of Hebrew origin ((G8276));", "definition": "a basket (as interwoven or wicker-work", "kjv": "basket."}, "G731": {"greek": "ἄῤῥητος", "translit": "árrhētos", "pronunciation": "ar'-hray-tos", "derivation": "from (G1) (as a negative particle) and the same as (G4490);", "definition": "unsaid, i.e. (by implication) inexpressible", "kjv": "unspeakable."}, "G5229": {"greek": "ὑπεραίρομαι", "translit": "hyperaíromai", "pronunciation": "hoop-er-ah'-ee-rom-ahee", "derivation": "middle voice from (G5228) and (G142);", "definition": "to raise oneself over, i.e. (figuratively) to become haughty", "kjv": "exalt self, be exalted above measure."}, "G4647": {"greek": "σκόλοψ", "translit": "skólops", "pronunciation": "skol'-ops", "derivation": "perhaps from the base of (G4628) and (G3700);", "definition": "withered at the front, i.e. a point or prickle (figuratively, a bodily annoyance or disability)", "kjv": "thorn."}, "G2236": {"greek": "ἥδιστα", "translit": "hḗdista", "pronunciation": "hay'-dis-tah", "derivation": "neuter plural of the superlative of the same as (G2234);", "definition": "with great pleasure", "kjv": "most (very) gladly."}, "G1981": {"greek": "ἐπισκηνόω", "translit": "episkēnóō", "pronunciation": "ep-ee-skay-no'-o", "derivation": "from (G1909) and (G4637);", "definition": "to tent upon, i.e. (figuratively) abide with", "kjv": "rest upon."}, "G2274": {"greek": "ἡττάω", "translit": "hēttáō", "pronunciation": "hayt-tah'-o", "derivation": "from the same as (G2276);", "definition": "to make worse, i.e. vanquish (literally or figuratively); by implication, to rate lower", "kjv": "be inferior, overcome."}, "G1550": {"greek": "ἐκδαπανάω", "translit": "ekdapanáō", "pronunciation": "ek-dap-an-ah'-o", "derivation": "from (G1537) and (G1159);", "definition": "to expend (wholly), i.e. (figuratively) exhaust", "kjv": "spend."}, "G3835": {"greek": "πανοῦργος", "translit": "panoûrgos", "pronunciation": "pan-oor'-gos", "derivation": "from (G3956) and (G2041);", "definition": "all-working, i.e. adroit (shrewd)", "kjv": "crafty."}, "G4882": {"greek": "συναποστέλλω", "translit": "synapostéllō", "pronunciation": "soon-ap-os-tel'-lo", "derivation": "from (G4862) and (G649);", "definition": "to despatch (on an errand) in company with", "kjv": "send with."}, "G2636": {"greek": "καταλαλία", "translit": "katalalía", "pronunciation": "kat-al-al-ee'-ah", "derivation": "from (G2637);", "definition": "defamation", "kjv": "backbiting, evil speaking."}, "G5587": {"greek": "ψιθυρισμός", "translit": "psithyrismós", "pronunciation": "psith-oo-ris-mos'", "derivation": "from a derivative of (a whisper; by implication, a slander; probably akin to (G5574));", "definition": "whispering, i.e. secret detraction", "kjv": "whispering."}, "G5450": {"greek": "φυσίωσις", "translit": "physíōsis", "pronunciation": "foo-see'-o-sis", "derivation": "from (G5448);", "definition": "inflation, i.e. (figuratively) haughtiness", "kjv": "swelling."}, "G4258": {"greek": "προαμαρτάνω", "translit": "proamartánō", "pronunciation": "pro-am-ar-tan'-o", "derivation": "from (G4253) and (G264);", "definition": "to sin previously (to conversion)", "kjv": "sin already, heretofore sin."}, "G2676": {"greek": "κατάρτισις", "translit": "katártisis", "pronunciation": "kat-ar'-tis-is", "derivation": "from (G2675);", "definition": "thorough equipment (subjectively)", "kjv": "perfection."}, "G664": {"greek": "ἀποτόμως", "translit": "apotómōs", "pronunciation": "ap-ot-om'-oce", "derivation": "adverb from a derivative of a comparative of (G575) and (to cut);", "definition": "abruptly, i.e. peremptorily", "kjv": "sharply(-ness)."}}